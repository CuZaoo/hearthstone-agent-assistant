{
  "name": "hearthstone-agent-assistant",
  "version": "0.1.0",
  "private": true,
  "description": "Read-only Hearthstone board analysis assistant for authorized testing.",
  "main": "dist/main/main/index.js",
  "type": "module",
  "scripts": {
    "postinstall": "electron-builder install-app-deps",
    "dev": "concurrently -k \"vite\" \"tsc -p tsconfig.main.json --watch\" \"wait-on http://localhost:5173 dist/main/main/index.js && electron .\"",
    "build": "npm run build:renderer && npm run build:main",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "package": "npm run build && electron-builder --win nsis",
    "catalog:build": "node scripts/build-card-catalog.mjs",
    "catalog:import-hdt": "node scripts/import-hdt-carddefs.mjs",
    "catalog:validate": "node scripts/validate-card-catalog.mjs assets/card-catalog.zhCN.json",
    "features:build": "electron scripts/build-image-features.mjs",
    "test": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.main.json"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.1",
    "keytar": "^7.9.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.4",
    "@types/react": "^19.0.8",
    "@types/react-dom": "^19.0.3",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^3.0.5",
    "wait-on": "^8.0.2"
  },
  "build": {
    "appId": "com.wang.hearthstone-agent-assistant",
    "productName": "炉石对局 Agent 助手",
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      }
    ],
    "win": {
      "target": "nsis"
    }
  }
}
